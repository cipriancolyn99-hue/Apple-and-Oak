/* Apple and Oak Desktop OS Styles */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body, #root {
  width: 100%;
  height: 100%;
  overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* Desktop icon animations */
@keyframes iconPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.desktop-icon-active {
  animation: iconPulse 2s ease-in-out infinite;
}

/* Window animations */
@keyframes windowOpen {
  from {
    opacity: 0;
    transform: scale(0.95) translateY(10px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* Live indicator pulse */
@keyframes livePulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.animate-live {
  animation: livePulse 2s ease-in-out infinite;
}

/* Glassmorphism effects */
.glass {
  background: rgba(15, 25, 35, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

/* Sound wave animation */
@keyframes soundWave {
  0%, 100% { height: 4px; }
  50% { height: 16px; }
}

.sound-wave {
  display: flex;
  align-items: center;
  gap: 2px;
}

.sound-wave span {
  width: 3px;
  background: currentColor;
  border-radius: 2px;
  animation: soundWave 1s ease-in-out infinite;
}

.sound-wave span:nth-child(2) { animation-delay: 0.1s; }
.sound-wave span:nth-child(3) { animation-delay: 0.2s; }
.sound-wave span:nth-child(4) { animation-delay: 0.3s; }

/* Clock glow */
.clock-glow {
  text-shadow: 0 0 10px rgba(45, 212, 191, 0.3);
}

/* Input date picker styling */
input[type="date"]::-webkit-calendar-picker-indicator {
