  return (
    <div className="absolute bottom-0 left-0 right-0 h-16 sm:h-20 bg-[#0a1628]/95 backdrop-blur-md border-t border-white/10 flex items-center px-2 sm:px-4 gap-1.5 sm:gap-3 z-50">
